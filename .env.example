# ---- Database (本地 PostgreSQL，開發用) ----
# 先在本機跑一個 postgres，建一個 noise 資料庫，填入連線字串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/noise?schema=public"

# ---- Anthropic Claude ----
# 必填：分群/研究/評分都會用到
ANTHROPIC_API_KEY=""

# ---- 新聞來源（選填）----
# 先純 RSS 起步可留空；要接 News API 再填
NEWS_API_KEY=""

# ---- Cron 保護（部署到 Vercel 後）----
# Vercel Cron 觸發 /api/cron/* 時驗證用的密鑰
CRON_SECRET=""

# ---- App ----
NEXT_PUBLIC_DEFAULT_LOCALE="zh-Hant"
