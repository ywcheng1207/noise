# ---- Database (本地 PostgreSQL 或 Neon) ----
# 本地：postgresql://postgres:postgres@localhost:5432/noise?schema=public
# Neon：DATABASE_URL 用 pooled 連線；DATABASE_URL_UNPOOLED 用 direct（Prisma migrate/db push 需要）
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASS@HOST/DB?sslmode=require"

# ---- Google Gemini ----
# 必填：分群/研究/評分都會用到（AI Studio key，aistudio.google.com）
GEMINI_API_KEY=""

# ---- 新聞來源（選填）----
# 先純 RSS 起步可留空；要接 News API 再填
NEWS_API_KEY=""

# ---- Cron 保護（部署到 Vercel 後）----
# Vercel Cron 觸發 /api/cron/* 時驗證用的密鑰
CRON_SECRET=""

# ---- App ----
NEXT_PUBLIC_DEFAULT_LOCALE="zh-Hant"
